---
const currentYear = new Date().getFullYear();
---

<footer class="bg-train-brown text-train-cream py-16 mt-auto">
  <div class="max-w-6xl mx-auto px-6">
    
    <!-- Google Map Embed -->
    <div class="mb-12 rounded-2xl overflow-hidden shadow-2xl">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3378.5!2d-98.9759!3d31.7138!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x86e50a8c7b8b0001%3A0x1!2s3600%20Stephen%20F%20Austin%20Dr%2C%20Brownwood%2C%20TX%2076801!5e0!3m2!1sen!2sus!4v1"
        width="100%" 
        height="250" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        title="Runaway Train Café location - right off Highway 377 in Brownwood"
        class="w-full"
      ></iframe>
    </div>
    
    <div class="grid md:grid-cols-4 gap-10">
      <!-- Hours -->
      <div>
        <h3 class="text-xl font-bold mb-5 text-train-gold">Hours</h3>
        <ul class="space-y-3 text-lg">
          <li><span class="font-semibold">Tue–Thu:</span> 11am–3pm</li>
          <li><span class="font-semibold">Fri–Sat:</span> 11am–8pm</li>
          <li class="text-train-cream/60"><span class="font-semibold">Sun–Mon:</span> Closed</li>
        </ul>
      </div>
      
      <!-- Location -->
      <div>
        <h3 class="text-xl font-bold mb-5 text-train-gold">Find Us</h3>
        <address class="not-italic space-y-2 text-lg">
          <p>3600 Stephen F. Austin Dr</p>
          <p>Brownwood, TX 76801</p>
          <p class="text-train-cream/70 text-sm mt-3">Right off Highway 377</p>
          <p class="mt-5">
            <a 
              href="https://maps.google.com/?q=3600+Stephen+F+Austin+Dr+Brownwood+TX+76801" 
              target="_blank"
              class="inline-flex items-center gap-2 bg-train-red hover:bg-red-700 text-white px-5 py-3 rounded-full transition-all hover:scale-105 font-semibold"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
              </svg>
              Get Directions
            </a>
          </p>
        </address>
      </div>
      
      <!-- Call -->
      <div>
        <h3 class="text-xl font-bold mb-5 text-train-gold">Call Us</h3>
        <a href="tel:+13256463333" class="text-3xl font-bold hover:text-train-gold transition-colors block mb-3">
          (325) 646-3333
        </a>
        <p class="text-train-cream/70">Call ahead for pickup orders</p>
      </div>
      
      <!-- Social -->
      <div>
        <h3 class="text-xl font-bold mb-5 text-train-gold">Follow Us</h3>
        <div class="flex gap-5">
          <a 
            href="https://www.facebook.com/RunawayTrainCafe" 
            target="_blank"
            class="bg-train-cream/10 hover:bg-train-gold hover:text-train-brown p-4 rounded-full transition-all"
            aria-label="Follow us on Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a 
            href="https://www.yelp.com/biz/runaway-train-cafe-brownwood" 
            target="_blank"
            class="bg-train-cream/10 hover:bg-train-gold hover:text-train-brown p-4 rounded-full transition-all"
            aria-label="Read our reviews on Yelp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308a1.072 1.072 0 011.596-.206l2.42 2.218c.592.543.264 1.513-.548 1.697l-.202-.204zm-5.025 3.152l4.942 1.606c.812.264.904 1.34.164 1.746l-2.828 1.556c-.74.406-1.528-.136-1.528-.934l-.75-3.974z"/>
              <path d="M12.34 3.094c.284-.71-.403-1.434-1.086-1.138L4.2 5.15c-.683.296-.74 1.234-.092 1.526l3.02 1.36c.324.146.708.045.93-.244l3.19-3.84c.226-.27.336-.607.092-.858zm-1.152 7.592c-.162-.936-1.206-1.24-1.838-.534l-3.4 3.79c-.632.706-.104 1.847.794 1.712l4.066-.612c.45-.068.786-.456.786-.922l.592-3.434z"/>
            </svg>
          </a>
          <a 
            href="https://www.tripadvisor.com/Restaurant_Review-g55540-d3727116-Reviews-Runaway_Train_Cafe-Brownwood_Texas.html" 
            target="_blank"
            class="bg-train-cream/10 hover:bg-train-gold hover:text-train-brown p-4 rounded-full transition-all"
            aria-label="Review us on TripAdvisor"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l1.963 2.135a5.997 5.997 0 004.04 10.432 5.997 5.997 0 005.997-5.997c0-.074-.003-.147-.006-.22a5.997 5.997 0 005.997 5.217 5.997 5.997 0 004.04-10.432L24 6.648h-4.35a13.573 13.573 0 00-7.644-2.353zM6.003 17.218a3.997 3.997 0 110-7.994 3.997 3.997 0 010 7.994zm11.994 0a3.997 3.997 0 110-7.994 3.997 3.997 0 010 7.994zM6.003 11.224a2 2 0 100 4 2 2 0 000-4zm11.994 0a2 2 0 100 4 2 2 0 000-4z"/>
            </svg>
          </a>
        </div>
        <p class="text-train-cream/60 text-sm mt-4">181 reviews &amp; counting</p>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="border-t border-train-cream/20 mt-12 pt-8 text-center">
      <p class="text-lg mb-2">🚂 <span class="font-semibold">Serving Brownwood since the days of the railroads.</span></p>
      <p class="text-sm text-train-cream/60">© {currentYear} Runaway Train Café. All rights reserved.</p>
    </div>
  </div>
</footer>
