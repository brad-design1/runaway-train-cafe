---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/menu", label: "Menu" },
  { href: "/about", label: "Our Story" },
  { href: "/gallery", label: "Gallery" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-train-brown text-train-cream sticky top-0 z-50 shadow-lg">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-20">
      <!-- Logo - Text based, no credit card image -->
      <a href="/" class="flex items-center gap-3 group">
        <span class="text-3xl" aria-hidden="true">🚂</span>
        <div class="flex flex-col leading-tight">
          <span class="text-lg md:text-xl font-bold group-hover:text-train-gold transition-colors">Runaway Train</span>
          <span class="text-xs md:text-sm text-train-gold tracking-widest uppercase">Café</span>
        </div>
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a 
            href={link.href} 
            class={`hover:text-train-gold transition-colors font-medium ${currentPath === link.href ? 'text-train-gold' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>
      
      <!-- CTA Buttons -->
      <div class="flex items-center gap-3">
        <a 
          href="tel:+13256463333" 
          class="bg-train-red hover:bg-red-700 text-white px-4 py-2.5 rounded-full font-semibold transition-all hover:scale-105 flex items-center gap-2 shadow-md"
          aria-label="Call to order"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          <span class="hidden sm:inline">Call Now</span>
        </a>
        
        <!-- Mobile menu button -->
        <button 
          id="mobile-menu-btn" 
          class="md:hidden p-2 hover:bg-train-cream/10 rounded-lg transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile Navigation -->
    <nav id="mobile-menu" class="md:hidden hidden pb-6" aria-label="Mobile navigation">
      <div class="flex flex-col gap-1 border-t border-train-cream/20 pt-4">
        {navLinks.map((link) => (
          <a 
            href={link.href} 
            class={`hover:text-train-gold hover:bg-train-cream/5 transition-colors py-3 px-4 rounded-lg font-medium ${currentPath === link.href ? 'text-train-gold bg-train-cream/5' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    btn?.setAttribute('aria-expanded', String(!isHidden));
  });
</script>
