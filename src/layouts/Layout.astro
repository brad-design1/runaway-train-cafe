---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Runaway Train Café in Brownwood, TX — authentic train car dining with the best burgers in town. Fresh half-pound burgers, homemade soup, Blue Bell ice cream." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/hamburger_orig.jpg" />
    <meta property="og:type" content="restaurant" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/8215572.png" />
    
    <!-- Google Fonts - Playfair Display for headers -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lora:wght@400;500&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    
    <!-- Schema.org markup for Google -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "Runaway Train Café",
      "image": "https://runawaytraincafe.com/hamburger_orig.jpg",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "3600 Stephen F. Austin Dr",
        "addressLocality": "Brownwood",
        "addressRegion": "TX",
        "postalCode": "76801",
        "addressCountry": "US"
      },
      "telephone": "+1-325-646-3333",
      "url": "https://runawaytraincafe.com",
      "servesCuisine": "American",
      "priceRange": "$$",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Wednesday", "Thursday"],
          "opens": "11:00",
          "closes": "15:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Friday", "Saturday"],
          "opens": "11:00",
          "closes": "20:00"
        }
      ]
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  
  body {
    font-family: 'Lora', Georgia, serif;
  }
  
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Playfair Display', Georgia, serif;
  }
</style>
