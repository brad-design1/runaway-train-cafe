---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Runaway Train Café | Brownwood's Train Car Diner Since 1940s">
  <Header />
  
  <!-- Hero Section -->
  <section class="relative h-[80vh] min-h-[600px] flex items-center justify-center">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/1383277711.jpg');">
      <div class="absolute inset-0 bg-gradient-to-b from-train-brown/60 via-train-brown/70 to-train-brown/90"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <p class="text-train-gold font-semibold tracking-widest uppercase mb-4 text-sm md:text-base">Est. Brownwood, Texas</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-train-cream mb-6 leading-tight">
        You're eating in an actual train car.
      </h1>
      <p class="text-xl md:text-2xl text-train-cream/90 mb-10 max-w-2xl mx-auto">
        Half-pound burgers. Homemade soup. Blue Bell ice cream. All served in a 1940s dining car that never left the station.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+13256463333" 
          class="bg-train-red hover:bg-red-700 text-white px-8 py-4 rounded-full font-bold text-lg transition-all hover:scale-105 inline-flex items-center justify-center gap-3 shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call to Order: (325) 646-3333
        </a>
        <a 
          href="https://maps.google.com/?q=3600+Stephen+F+Austin+Dr+Brownwood+TX+76801" 
          target="_blank"
          class="bg-transparent border-2 border-train-cream hover:bg-train-cream hover:text-train-brown text-train-cream px-8 py-4 rounded-full font-bold text-lg transition-all inline-flex items-center justify-center gap-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
          </svg>
          3600 Stephen F. Austin Dr
        </a>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-train-cream/60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>
  
  <!-- Hours Strip -->
  <section class="bg-train-brown border-y-4 border-train-gold py-5">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-16 text-train-cream text-center">
        <div class="flex items-center gap-3">
          <span class="text-train-gold text-2xl">🚂</span>
          <span class="text-lg"><strong>Tue–Thu</strong> 11am–3pm</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-train-cream/30"></div>
        <div class="flex items-center gap-3">
          <span class="text-train-gold text-2xl">🍔</span>
          <span class="text-lg"><strong>Fri–Sat</strong> 11am–8pm</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-train-cream/30"></div>
        <div class="flex items-center gap-3">
          <span class="opacity-60">Closed Sun & Mon</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- The Hook - Why This Place -->
  <section class="py-20 md:py-28 bg-train-cream">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-train-brown mb-6">
          Nobody else in Texas has this.
        </h2>
        <p class="text-xl text-train-brown/70 max-w-3xl mx-auto">
          In the 1940s, this was a real dining car rolling through Texas. Now it sits at 3600 Stephen F. Austin, 
          and you can slide into the same booths where travelers ate 80 years ago.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="relative">
          <img 
            src="/2698530_orig.jpg" 
            alt="Original train car booths inside Runaway Train Café" 
            class="rounded-2xl shadow-2xl w-full"
          />
          <div class="absolute -bottom-4 -right-4 bg-train-gold text-train-brown px-4 py-2 rounded-lg font-bold shadow-lg">
            Original 1940s booths
          </div>
        </div>
        <div class="space-y-6">
          <div class="flex gap-4 items-start">
            <div class="bg-train-red/10 rounded-full p-3 shrink-0">
              <span class="text-2xl">🪑</span>
            </div>
            <div>
              <h3 class="font-bold text-train-brown text-lg mb-1">The booths are original.</h3>
              <p class="text-train-brown/70">Same seats, same curves, same feeling as 1940s railroad dining. We kept everything intact.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="bg-train-red/10 rounded-full p-3 shrink-0">
              <span class="text-2xl">🍦</span>
            </div>
            <div>
              <h3 class="font-bold text-train-brown text-lg mb-1">Old-fashioned ice cream counter.</h3>
              <p class="text-train-brown/70">Grab a stool. Order a milkshake. This is how your grandparents did it.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="bg-train-red/10 rounded-full p-3 shrink-0">
              <span class="text-2xl">👋</span>
            </div>
            <div>
              <h3 class="font-bold text-train-brown text-lg mb-1">Small town service.</h3>
              <p class="text-train-brown/70">We know the regulars by name. First-timers get treated like family anyway.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- The Burger Section -->
  <section class="py-20 md:py-28 bg-train-brown">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <span class="text-train-gold font-bold uppercase tracking-wider text-sm">The Main Event</span>
          <h2 class="text-3xl md:text-5xl font-bold text-train-cream mt-3 mb-6">
            Half a pound. Fresh beef. No freezer.
          </h2>
          <p class="text-lg text-train-cream/80 mb-6 leading-relaxed">
            Every burger here starts at 8 ounces. We grind the beef ourselves, form the patties by hand, 
            and cook them when you order. Not before. Nothing sits under a heat lamp.
          </p>
          <div class="bg-train-cream/10 rounded-xl p-6 mb-8">
            <p class="text-train-gold font-semibold mb-3">Customer favorites:</p>
            <ul class="space-y-2 text-train-cream/90">
              <li class="flex items-center gap-2">
                <span class="text-train-gold">→</span>
                <strong>Jalapeño Bacon Cheeseburger</strong> — spicy bacon, melted cheddar
              </li>
              <li class="flex items-center gap-2">
                <span class="text-train-gold">→</span>
                <strong>Mushroom Swiss</strong> — sautéed mushrooms, Swiss cheese
              </li>
            </ul>
          </div>
          <a href="/menu" class="bg-train-red hover:bg-red-700 text-white px-6 py-3 rounded-full font-bold transition-all hover:scale-105 inline-flex items-center gap-2 shadow-lg">
            See the Full Menu
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
        <div class="order-1 md:order-2">
          <img 
            src="/hamburger_orig.jpg" 
            alt="Fresh half-pound burger at Runaway Train Café" 
            class="rounded-2xl shadow-2xl w-full"
          />
        </div>
      </div>
    </div>
  </section>
  
  <!-- More Than Burgers Grid -->
  <section class="py-20 md:py-28 bg-train-cream">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-train-brown mb-4">
          Not just burgers.
        </h2>
        <p class="text-lg text-train-brown/70">
          Homemade soup every day. Sandwiches made when you order. And Blue Bell ice cream, because this is Texas.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="group relative overflow-hidden rounded-2xl shadow-lg">
          <img src="/3469504_orig.jpg" alt="Homemade soup of the day" class="w-full h-72 object-cover transition-transform group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-train-brown via-train-brown/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-xl font-bold text-train-cream mb-2">Homemade Soup</h3>
            <p class="text-train-cream/80 text-sm">Different recipe every day. Ask what's on when you call.</p>
          </div>
        </div>
        
        <div class="group relative overflow-hidden rounded-2xl shadow-lg">
          <img src="/6185791_orig.jpg" alt="Fresh sandwiches" class="w-full h-72 object-cover transition-transform group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-train-brown via-train-brown/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-xl font-bold text-train-cream mb-2">Sandwiches</h3>
            <p class="text-train-cream/80 text-sm">BLTs, clubs, grilled cheese. The classics, done right.</p>
          </div>
        </div>
        
        <div class="group relative overflow-hidden rounded-2xl shadow-lg">
          <img src="/2407565_orig.jpg" alt="Blue Bell ice cream" class="w-full h-72 object-cover transition-transform group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-train-brown via-train-brown/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-xl font-bold text-train-cream mb-2">Blue Bell Ice Cream</h3>
            <p class="text-train-cream/80 text-sm">Single scoop. Double scoop. Milkshakes. Root beer floats.</p>
          </div>
        </div>
      </div>
      
      <div class="text-center mt-10">
        <p class="text-train-brown/60 text-sm">
          Pro tip: The soup & half sandwich combo is our most popular lunch order.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Social Proof -->
  <section class="py-16 md:py-24 bg-train-red">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-3 bg-white/10 rounded-full px-6 py-2 mb-6">
          <span class="text-3xl font-bold text-white">4.5</span>
          <div class="flex text-train-gold">
            {[1,2,3,4].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-50" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </div>
          <span class="text-white/80 text-sm">181 reviews on Yelp</span>
        </div>
        <h2 class="text-2xl md:text-4xl font-bold text-white mb-8">
          What people are saying
        </h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <blockquote class="bg-white/10 rounded-xl p-6 backdrop-blur-sm">
          <p class="text-white/90 mb-4 italic">"Went for the train car, stayed for the burgers. Best half-pound burger I've had in years."</p>
          <footer class="text-train-gold text-sm font-semibold">— Yelp Review</footer>
        </blockquote>
        <blockquote class="bg-white/10 rounded-xl p-6 backdrop-blur-sm">
          <p class="text-white/90 mb-4 italic">"My kids didn't want to leave. The ice cream counter made their whole week."</p>
          <footer class="text-train-gold text-sm font-semibold">— Yelp Review</footer>
        </blockquote>
        <blockquote class="bg-white/10 rounded-xl p-6 backdrop-blur-sm">
          <p class="text-white/90 mb-4 italic">"If you're passing through Brownwood, this is the only lunch stop. Trust me."</p>
          <footer class="text-train-gold text-sm font-semibold">— Yelp Review</footer>
        </blockquote>
      </div>
      
      <div class="text-center mt-10">
        <a 
          href="https://www.yelp.com/biz/runaway-train-cafe-brownwood" 
          target="_blank"
          class="inline-flex items-center gap-2 text-white hover:text-train-gold transition-colors font-semibold"
        >
          Read all 181 reviews on Yelp
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
            <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
          </svg>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Final CTA -->
  <section class="py-20 md:py-28 bg-train-cream">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-train-brown mb-6">
        Come hungry. Leave happy.
      </h2>
      <p class="text-xl text-train-brown/70 mb-10">
        3600 Stephen F. Austin Dr, Brownwood, TX 76801<br/>
        Open Tue–Thu 11am–3pm, Fri–Sat 11am–8pm
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+13256463333" 
          class="bg-train-red hover:bg-red-700 text-white px-10 py-5 rounded-full font-bold text-xl transition-all hover:scale-105 inline-flex items-center justify-center gap-3 shadow-xl"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          (325) 646-3333
        </a>
        <a 
          href="https://maps.google.com/?q=3600+Stephen+F+Austin+Dr+Brownwood+TX+76801" 
          target="_blank"
          class="bg-train-brown hover:bg-train-brown/80 text-train-cream px-10 py-5 rounded-full font-bold text-xl transition-all inline-flex items-center justify-center gap-3 shadow-xl"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
          </svg>
          Get Directions
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
