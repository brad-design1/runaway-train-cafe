---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Runaway Train Café | Best Burgers in Brownwood, TX">
  <Header />
  
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center justify-center">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/1383277711.jpg');">
      <div class="absolute inset-0 bg-train-brown/70"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-train-cream mb-6 leading-tight">
        Step Back in Time
      </h1>
      <p class="text-xl md:text-2xl text-train-cream/90 mb-8">
        The best burgers in Brownwood — served in an authentic 1940s train car.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+13256463333" 
          class="bg-train-red hover:bg-red-800 text-white px-8 py-4 rounded-full font-bold text-lg transition-colors inline-flex items-center justify-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call (325) 646-3333
        </a>
        <a 
          href="https://maps.google.com/?q=3600+Stephen+F+Austin+Dr+Brownwood+TX+76801" 
          target="_blank"
          class="bg-train-cream hover:bg-white text-train-brown px-8 py-4 rounded-full font-bold text-lg transition-colors inline-flex items-center justify-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
          </svg>
          Get Directions
        </a>
      </div>
    </div>
  </section>
  
  <!-- Hours & Location Quick Info -->
  <section class="bg-train-red text-white py-6">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-center gap-6 md:gap-12 text-center md:text-left">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span><strong>Tue-Thu:</strong> 11am-3pm | <strong>Fri-Sat:</strong> 11am-8pm</span>
        </div>
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>3600 Stephen F. Austin Dr, Brownwood, TX</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Featured Food Section -->
  <section class="py-16 md:py-24 bg-train-cream">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <img 
            src="/hamburger_orig.jpg" 
            alt="Half-pound fresh burger at Runaway Train Café" 
            class="rounded-2xl shadow-2xl w-full"
          />
        </div>
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-train-brown mb-6">
            Fresh Half-Pound Burgers
          </h2>
          <p class="text-lg text-train-brown/80 mb-6 leading-relaxed">
            All our burgers are made with fresh, never-frozen beef — half a pound of pure deliciousness. 
            Order with or without cheese, and don't miss our customer favorites: the <strong>bacon cheeseburger 
            with jalapeño bacon</strong> and the <strong>mushroom & Swiss burger</strong>.
          </p>
          <p class="text-lg text-train-brown/80 mb-8 leading-relaxed">
            Every burger comes with your choice of delicious French fries or crispy tots.
          </p>
          <a href="/menu" class="bg-train-red hover:bg-red-800 text-white px-6 py-3 rounded-full font-semibold transition-colors inline-flex items-center gap-2">
            View Full Menu
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- The Train Car Story -->
  <section class="py-16 md:py-24 bg-train-brown text-train-cream">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <span class="text-train-gold font-semibold uppercase tracking-wider">Our Story</span>
          <h2 class="text-3xl md:text-4xl font-bold mt-2 mb-6">
            Dine in an Authentic Train Car
          </h2>
          <p class="text-lg text-train-cream/80 mb-6 leading-relaxed">
            Runaway Train Café is the most unique dining experience in Brownwood. As soon as you walk in, 
            you feel what it was like to dine in an authentic dining train car with all of its originality.
          </p>
          <p class="text-lg text-train-cream/80 mb-8 leading-relaxed">
            Take a seat in one of our cozy booths or grab a stool at the old-fashioned ice cream counter. 
            You're always greeted by our friendly staff, ready to serve you the best meal in town.
          </p>
          <a href="/about" class="bg-train-gold hover:bg-yellow-600 text-train-brown px-6 py-3 rounded-full font-semibold transition-colors inline-flex items-center gap-2">
            Read Our Story
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
        <div class="order-1 md:order-2">
          <img 
            src="/2698530_orig.jpg" 
            alt="Interior of Runaway Train Café train car" 
            class="rounded-2xl shadow-2xl w-full"
          />
        </div>
      </div>
    </div>
  </section>
  
  <!-- More Favorites Section -->
  <section class="py-16 md:py-24 bg-train-cream">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-train-brown mb-12">
        More Than Just Burgers
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <img src="/3469504_orig.jpg" alt="Homemade soup" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-bold text-train-brown mb-2">Homemade Soup</h3>
            <p class="text-train-brown/70">Fresh, homemade soup daily. Try our famous soup & half sandwich combo!</p>
          </div>
        </div>
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <img src="/6185791_orig.jpg" alt="Sandwiches" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-bold text-train-brown mb-2">Amazing Sandwiches</h3>
            <p class="text-train-brown/70">From classic favorites to our specialty creations — always made fresh.</p>
          </div>
        </div>
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <img src="/2407565_orig.jpg" alt="Blue Bell ice cream" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-bold text-train-brown mb-2">Blue Bell Ice Cream</h3>
            <p class="text-train-brown/70">Finish with a single or double scoop of Texas's favorite ice cream!</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Social Proof / Reviews -->
  <section class="py-16 md:py-20 bg-train-red text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="text-4xl font-bold">4.5</span>
        <div class="flex text-train-gold">
          {[1,2,3,4].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" style="clip-path: inset(0 50% 0 0);">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        </div>
        <span class="text-lg opacity-90">on Yelp</span>
      </div>
      <p class="text-2xl md:text-3xl font-semibold italic mb-4">
        "The best burgers you'll ever taste!"
      </p>
      <p class="opacity-75">
        Over 180 reviews from happy customers
      </p>
      <a 
        href="https://www.yelp.com/biz/runaway-train-cafe-brownwood" 
        target="_blank"
        class="mt-6 inline-flex items-center gap-2 text-white/90 hover:text-white transition-colors"
      >
        Read our reviews on Yelp
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
          <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
        </svg>
      </a>
    </div>
  </section>
  
  <Footer />
</Layout>
