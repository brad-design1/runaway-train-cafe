---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Runaway Train Café | Brownwood's Train Car Diner Since 1940s">
  <Header />
  
  <!-- Hero Section -->
  <section class="hero-section relative h-[90vh] min-h-[650px] flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img 
        src="/1383277711.jpg" 
        alt="" 
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    
    <!-- Gradient Overlay — Stronger layers for guaranteed text visibility -->
    <div class="absolute inset-0 bg-gradient-to-b from-train-brown/60 via-train-brown/70 to-train-brown/95"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-train-brown/90 via-train-brown/30 to-transparent"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    
    <!-- Content -->
    <div class="hero-content relative z-10 text-center px-6 max-w-5xl mx-auto">
      <p class="text-train-gold font-bold tracking-[0.25em] uppercase mb-6 text-sm md:text-base text-shadow">
        Est. Brownwood, Texas
      </p>
      <h1 class="hero-title mb-8">
        You're eating in an actual train car.
      </h1>
      <p class="hero-subtitle mb-12">
        Half-pound burgers. Homemade soup. Blue Bell ice cream. All served in a 1940s dining car that never left the station.
      </p>
      <div class="flex flex-col sm:flex-row gap-5 justify-center">
        <a 
          href="tel:+13256463333" 
          class="btn-primary text-lg inline-flex items-center justify-center gap-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          Call to Order: (325) 646-3333
        </a>
        <a 
          href="https://maps.google.com/?q=3600+Stephen+F+Austin+Dr+Brownwood+TX+76801" 
          target="_blank"
          class="btn-secondary text-lg inline-flex items-center justify-center gap-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
          </svg>
          3600 Stephen F. Austin Dr
        </a>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-train-cream/70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>
  
  <!-- Hours Strip -->
  <section class="bg-train-brown border-y-4 border-train-gold py-5">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-16 text-train-cream text-center">
        <div class="flex items-center gap-3">
          <span class="text-train-gold text-2xl">🚂</span>
          <span class="text-lg"><strong>Tue–Thu</strong> 11am–3pm</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-train-cream/30" aria-hidden="true"></div>
        <div class="flex items-center gap-3">
          <span class="text-train-gold text-2xl">🍔</span>
          <span class="text-lg"><strong>Fri–Sat</strong> 11am–8pm</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-train-cream/30" aria-hidden="true"></div>
        <div class="flex items-center gap-3">
          <span class="opacity-60">Closed Sun &amp; Mon</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- The Hook - Why This Place -->
  <section class="py-24 md:py-32 bg-train-cream">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-4xl md:text-5xl font-bold text-train-brown mb-8">
          Nobody else in Texas has this.
        </h2>
        <p class="text-xl md:text-2xl text-train-brown/70 max-w-3xl mx-auto leading-relaxed">
          In the 1940s, this was a real dining car rolling through Texas. Now it sits at 3600 Stephen F. Austin, 
          and you can slide into the same booths where travelers ate 80 years ago.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="relative">
          <img 
            src="/2698530_orig.jpg" 
            alt="Original train car booths inside Runaway Train Café" 
            class="rounded-2xl shadow-2xl w-full"
            loading="lazy"
            width="600"
            height="400"
          />
          <div class="absolute -bottom-5 -right-5 bg-train-gold text-train-brown px-5 py-3 rounded-xl font-bold shadow-xl text-sm md:text-base">
            Original 1940s booths
          </div>
        </div>
        <div class="space-y-8">
          <div class="flex gap-5 items-start">
            <div class="bg-train-red/10 rounded-2xl p-4 shrink-0">
              <span class="text-3xl">🪑</span>
            </div>
            <div>
              <h3 class="font-bold text-train-brown text-xl mb-2">The booths are original.</h3>
              <p class="text-train-brown/70 text-lg">Same seats, same curves, same feeling as 1940s railroad dining. We kept everything intact.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <div class="bg-train-red/10 rounded-2xl p-4 shrink-0">
              <span class="text-3xl">🍦</span>
            </div>
            <div>
              <h3 class="font-bold text-train-brown text-xl mb-2">Old-fashioned ice cream counter.</h3>
              <p class="text-train-brown/70 text-lg">Grab a stool. Order a milkshake. This is how your grandparents did it.</p>
            </div>
          </div>
          <div class="flex gap-5 items-start">
            <div class="bg-train-red/10 rounded-2xl p-4 shrink-0">
              <span class="text-3xl">👋</span>
            </div>
            <div>
              <h3 class="font-bold text-train-brown text-xl mb-2">Small town service.</h3>
              <p class="text-train-brown/70 text-lg">We know the regulars by name. First-timers get treated like family anyway.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- The Burger Section -->
  <section class="py-24 md:py-32 bg-train-brown">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <span class="text-train-gold font-bold uppercase tracking-[0.2em] text-sm">The Main Event</span>
          <h2 class="text-4xl md:text-5xl font-bold text-train-cream mt-4 mb-8 text-shadow">
            Half a pound. Fresh beef. No freezer.
          </h2>
          <p class="text-xl text-train-cream/85 mb-8 leading-relaxed">
            Every burger here starts at 8 ounces. We grind the beef ourselves, form the patties by hand, 
            and cook them when you order. Not before. Nothing sits under a heat lamp.
          </p>
          <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-8 mb-10 border border-train-gold/30 shadow-lg">
            <p class="text-train-gold font-bold mb-5 text-xl">🔥 Customer favorites:</p>
            <ul class="space-y-4 text-lg">
              <li class="flex items-start gap-4 bg-white/10 rounded-xl p-4">
                <span class="text-train-gold text-2xl">→</span>
                <div>
                  <strong class="text-train-cream text-xl">Jalapeño Bacon Cheeseburger</strong>
                  <p class="text-train-cream/80 mt-1">Spicy bacon, melted cheddar, fresh jalapeños</p>
                </div>
              </li>
              <li class="flex items-start gap-4 bg-white/10 rounded-xl p-4">
                <span class="text-train-gold text-2xl">→</span>
                <div>
                  <strong class="text-train-cream text-xl">Mushroom Swiss</strong>
                  <p class="text-train-cream/80 mt-1">Sautéed mushrooms, melted Swiss cheese</p>
                </div>
              </li>
            </ul>
          </div>
          <a href="/menu" class="btn-primary text-lg inline-flex items-center gap-3">
            See the Full Menu
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
        <div class="order-1 md:order-2">
          <img 
            src="/hamburger_orig.jpg" 
            alt="Fresh half-pound burger at Runaway Train Café" 
            class="rounded-2xl shadow-2xl w-full"
            loading="lazy"
            width="600"
            height="500"
          />
        </div>
      </div>
    </div>
  </section>
  
  <!-- Food Photo Strip — Make Stomachs Growl -->
  <section class="py-8 bg-train-cream overflow-hidden">
    <div class="flex gap-4 animate-none md:grid md:grid-cols-4">
      <div class="shrink-0 w-72 md:w-auto overflow-hidden rounded-xl shadow-lg">
        <img 
          src="/hamburger_orig.jpg" 
          alt="Half-pound burger" 
          class="w-full h-48 object-cover hover:scale-105 transition-transform"
          loading="lazy"
          width="288"
          height="192"
        />
      </div>
      <div class="shrink-0 w-72 md:w-auto overflow-hidden rounded-xl shadow-lg">
        <img 
          src="/3469504_orig.jpg" 
          alt="Homemade soup" 
          class="w-full h-48 object-cover hover:scale-105 transition-transform"
          loading="lazy"
          width="288"
          height="192"
        />
      </div>
      <div class="shrink-0 w-72 md:w-auto overflow-hidden rounded-xl shadow-lg">
        <img 
          src="/9548696_orig.jpg" 
          alt="Ice cream counter" 
          class="w-full h-48 object-cover hover:scale-105 transition-transform"
          loading="lazy"
          width="288"
          height="192"
        />
      </div>
      <div class="shrink-0 w-72 md:w-auto overflow-hidden rounded-xl shadow-lg">
        <img 
          src="/219173_orig.jpg" 
          alt="Fresh food" 
          class="w-full h-48 object-cover hover:scale-105 transition-transform"
          loading="lazy"
          width="288"
          height="192"
        />
      </div>
    </div>
  </section>
  
  <!-- More Than Burgers Grid -->
  <section class="py-24 md:py-32 bg-train-cream">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-train-brown mb-6">
          Not just burgers.
        </h2>
        <p class="text-xl text-train-brown/70 max-w-2xl mx-auto">
          Homemade soup every day. Sandwiches made when you order. And Blue Bell ice cream, because this is Texas.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="image-card group h-80 shadow-xl card-hover">
          <img 
            src="/3469504_orig.jpg" 
            alt="Homemade soup of the day" 
            loading="lazy"
            width="400"
            height="320"
          />
          <div class="image-card-overlay"></div>
          <div class="image-card-content">
            <h3 class="image-card-title">Homemade Soup</h3>
            <p class="image-card-text">Different recipe every day. Ask what's on when you call.</p>
          </div>
        </div>
        
        <!-- Card 2 -->
        <div class="image-card group h-80 shadow-xl card-hover">
          <img 
            src="/6185791_orig.jpg" 
            alt="Fresh sandwiches" 
            loading="lazy"
            width="400"
            height="320"
          />
          <div class="image-card-overlay"></div>
          <div class="image-card-content">
            <h3 class="image-card-title">Sandwiches</h3>
            <p class="image-card-text">BLTs, clubs, grilled cheese. The classics, done right.</p>
          </div>
        </div>
        
        <!-- Card 3 -->
        <div class="image-card group h-80 shadow-xl card-hover">
          <img 
            src="/2407565_orig.jpg" 
            alt="Blue Bell ice cream" 
            loading="lazy"
            width="400"
            height="320"
          />
          <div class="image-card-overlay"></div>
          <div class="image-card-content">
            <h3 class="image-card-title">Blue Bell Ice Cream</h3>
            <p class="image-card-text">Single scoop. Double scoop. Milkshakes. Root beer floats.</p>
          </div>
        </div>
      </div>
      
      <div class="text-center mt-12">
        <p class="text-train-brown/60 text-lg italic">
          Pro tip: The soup &amp; half sandwich combo is our most popular lunch order.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Social Proof -->
  <section class="py-24 md:py-32 bg-train-red relative overflow-hidden">
    <!-- Subtle texture overlay -->
    <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23000000&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-4 bg-white/15 rounded-full px-8 py-4 mb-8 backdrop-blur-sm">
          <span class="text-4xl font-bold text-white">4.5</span>
          <div class="flex text-train-gold">
            {[1,2,3,4].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 opacity-50" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </div>
          <span class="text-white/80">181 reviews on Yelp</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-10 text-shadow">
          What people are saying
        </h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <blockquote class="testimonial-card">
          <p class="testimonial-text text-lg mb-5">"Went for the train car, stayed for the burgers. Best half-pound burger I've had in years."</p>
          <footer class="text-train-gold font-bold">— Yelp Review</footer>
        </blockquote>
        <blockquote class="testimonial-card">
          <p class="testimonial-text text-lg mb-5">"My kids didn't want to leave. The ice cream counter made their whole week."</p>
          <footer class="text-train-gold font-bold">— Yelp Review</footer>
        </blockquote>
        <blockquote class="testimonial-card">
          <p class="testimonial-text text-lg mb-5">"If you're passing through Brownwood, this is the only lunch stop. Trust me."</p>
          <footer class="text-train-gold font-bold">— Yelp Review</footer>
        </blockquote>
      </div>
      
      <div class="text-center mt-12">
        <a 
          href="https://www.yelp.com/biz/runaway-train-cafe-brownwood" 
          target="_blank"
          class="inline-flex items-center gap-3 text-white hover:text-train-gold transition-colors font-bold text-lg"
        >
          Read all 181 reviews on Yelp
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
            <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
          </svg>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Final CTA -->
  <section class="py-24 md:py-32 bg-train-cream">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-train-brown mb-8">
        Come hungry. Leave happy.
      </h2>
      <p class="text-xl md:text-2xl text-train-brown/70 mb-12">
        3600 Stephen F. Austin Dr, Brownwood, TX 76801<br/>
        <span class="text-train-brown font-semibold">Tue–Thu 11am–3pm • Fri–Sat 11am–8pm</span>
      </p>
      <div class="flex flex-col sm:flex-row gap-5 justify-center">
        <a 
          href="tel:+13256463333" 
          class="btn-primary text-xl px-12 py-6 inline-flex items-center justify-center gap-4"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          (325) 646-3333
        </a>
        <a 
          href="https://maps.google.com/?q=3600+Stephen+F+Austin+Dr+Brownwood+TX+76801" 
          target="_blank"
          class="bg-train-brown hover:bg-train-brown-light text-train-cream px-12 py-6 rounded-full font-bold text-xl transition-all inline-flex items-center justify-center gap-4 shadow-xl"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
          </svg>
          Get Directions
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
