---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | Runaway Train Café">
  <Header />
  
  <!-- Hero -->
  <section class="bg-train-brown text-train-cream py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-xl opacity-90">
        We'd love to hear from you!
      </p>
    </div>
  </section>
  
  <!-- Contact Info + Map -->
  <section class="py-12 md:py-16 bg-train-cream">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl font-bold text-train-brown mb-6">Get in Touch</h2>
          
          <div class="space-y-6">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="bg-train-red rounded-full p-3 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-train-brown">Phone</h3>
                <a href="tel:+13256463333" class="text-train-red hover:underline text-lg font-bold">
                  (325) 646-3333
                </a>
                <p class="text-train-brown/70 text-sm mt-1">Call for orders or reservations</p>
              </div>
            </div>
            
            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="bg-train-red rounded-full p-3 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-train-brown">Address</h3>
                <p class="text-train-brown/80">
                  3600 Stephen F. Austin Dr<br />
                  Brownwood, TX 76801
                </p>
                <a 
                  href="https://maps.google.com/?q=3600+Stephen+F+Austin+Dr+Brownwood+TX+76801" 
                  target="_blank"
                  class="text-train-red hover:underline text-sm mt-2 inline-flex items-center gap-1"
                >
                  Get directions
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                    <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                  </svg>
                </a>
              </div>
            </div>
            
            <!-- Hours -->
            <div class="flex items-start gap-4">
              <div class="bg-train-red rounded-full p-3 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-train-brown">Hours</h3>
                <ul class="text-train-brown/80 space-y-1">
                  <li><span class="font-medium">Tuesday - Thursday:</span> 11am - 3pm</li>
                  <li><span class="font-medium">Friday - Saturday:</span> 11am - 8pm</li>
                  <li><span class="font-medium">Sunday - Monday:</span> Closed</li>
                </ul>
              </div>
            </div>
            
            <!-- Social -->
            <div class="flex items-start gap-4">
              <div class="bg-train-red rounded-full p-3 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-train-brown">Follow Us</h3>
                <div class="flex gap-4 mt-2">
                  <a 
                    href="https://www.facebook.com/RunawayTrainCafe" 
                    target="_blank"
                    class="text-train-brown hover:text-train-red transition-colors"
                    aria-label="Facebook"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                  </a>
                  <a 
                    href="https://www.yelp.com/biz/runaway-train-cafe-brownwood" 
                    target="_blank"
                    class="text-train-brown hover:text-train-red transition-colors"
                    aria-label="Yelp"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308a1.072 1.072 0 011.596-.206l2.42 2.218c.592.543.264 1.513-.548 1.697l-.202-.204zm-5.025 3.152l4.942 1.606c.812.264.904 1.34.164 1.746l-2.828 1.556c-.74.406-1.528-.136-1.528-.934l-.75-3.974z"/>
                      <path d="M12.34 3.094c.284-.71-.403-1.434-1.086-1.138L4.2 5.15c-.683.296-.74 1.234-.092 1.526l3.02 1.36c.324.146.708.045.93-.244l3.19-3.84c.226-.27.336-.607.092-.858zm-1.152 7.592c-.162-.936-1.206-1.24-1.838-.534l-3.4 3.79c-.632.706-.104 1.847.794 1.712l4.066-.612c.45-.068.786-.456.786-.922l.592-3.434z"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Map -->
        <div>
          <h2 class="text-2xl font-bold text-train-brown mb-6">Find Us</h2>
          <div class="rounded-2xl overflow-hidden shadow-lg h-96">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3378.2!2d-98.98!3d31.71!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8655c6a8e0000001%3A0x1!2s3600%20Stephen%20F%20Austin%20Dr%2C%20Brownwood%2C%20TX%2076801!5e0!3m2!1sen!2sus!4v1"
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Runaway Train Café Location"
            ></iframe>
          </div>
          <p class="text-sm text-train-brown/60 mt-3">
            Located on Stephen F. Austin Dr in Brownwood — you can't miss the train car!
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
